{
  "name": "fun-notification-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Enterprise Realtime Animated Notification System Monorepo",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build:shared": "npm run build --workspaces --if-present",
    "dev:backend": "npm run dev --workspace=apps/backend",
    "dev:dashboard": "npm run dev --workspace=apps/sender-dashboard",
    "start:electron": "npm start --workspace=apps/electron"
  },
  "devDependencies": {
    "electron": "^30.5.1",
    "typescript": "^5.4.5"
  }
}
